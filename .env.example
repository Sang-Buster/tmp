# =============================================================================
# OLLAMA / LLM CONFIGURATION
# =============================================================================

OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2:3b-instruct-q4_K_M
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# LLM Assistance - auto-assists when agent comm quality drops below PT
# When enabled, LLM provides tactical guidance to help agents:
# - Escape jamming zones to restore communication
# - Continue progressing toward destination
LLM_ASSISTANCE_ENABLED=true

# =============================================================================
# QDRANT CONFIGURATION (unified storage for agent telemetry and conversation logs)
# =============================================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333

# =============================================================================
# SIMULATION BOUNDARIES
# =============================================================================

X_MIN=-200
X_MAX=200
Y_MIN=-200
Y_MAX=200
Z_MIN=0
Z_MAX=200

# Mission endpoint / destination
MISSION_END_X=35
MISSION_END_Y=150
MISSION_END_Z=30

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

NUM_AGENTS=7

# Agent position mode: "random" or "manual"
AGENT_POSITION_MODE=manual

# Manual agent positions (JSON array of [x, y, z] positions)
# Uncomment and modify if AGENT_POSITION_MODE=manual
AGENT_POSITIONS_MANUAL=[[-5, 14, 20], [-5, -19, 25], [0, 0, 15], [35, -4, 20], [68, 0, 25], [72, 13, 15], [72, -18, 20]]

# Movement parameters
MAX_MOVEMENT_PER_STEP=1.0
UPDATE_FREQ=10.0

# =============================================================================
# OBSTACLE / JAMMING ZONE CONFIGURATION
# =============================================================================

# Number of obstacles (0 for none, or set positions manually)
NUM_OBSTACLES=3

# Obstacle position mode: "random" or "manual"
OBSTACLE_POSITION_MODE=manual

# Manual obstacle positions (JSON array of [x, y, z, radius] tuples)
# Uncomment and modify to add predefined obstacles
OBSTACLES_MANUAL=[[-5, 70, 10, 20]]

# Random obstacle parameters (if OBSTACLE_POSITION_MODE=random)
OBSTACLE_RADIUS_MIN=3.0
OBSTACLE_RADIUS_MAX=8.0

# =============================================================================
# FORMATION CONTROL PARAMETERS (Communication-Aware)
# =============================================================================

# Default formation type:
# - "communication_aware" (default): Uses communication quality metrics
# - "v_formation": Classic V-shape
# - "line": Side-by-side
# - "circle": Circular arrangement
# - "wedge": Arrow shape
# - "column": Single file
# - "diamond": Diamond pattern
DEFAULT_FORMATION=communication_aware

# Communication quality parameters (for communication_aware formation)
ALPHA=1e-5
DELTA=2.0
R0=5.0
V_PATH_LOSS=3.0
PT=0.94

# Convergence: iterations of stable Jn before moving to destination
CONVERGENCE_THRESHOLD=20

# =============================================================================
# PATH PLANNING CONFIGURATION
# =============================================================================

# Default path algorithm:
# - "direct" (default): Direct destination with behavior-based obstacle avoidance
# - "astar": A* pathfinding
# - "theta_star": Theta* with path smoothing
# - "dijkstra": Dijkstra's algorithm
# - "bfs": Breadth-First Search
# - "greedy": Greedy Best-First
# - "bi_astar": Bidirectional A*
# - "msp": Minimum Spanning Tree
DEFAULT_PATH_ALGORITHM=astar

# Grid-based path planning parameters
VOXEL_SIZE=2.0
PATH_BOUNDS_MARGIN=50.0

# Behavior-based control parameters
ATTRACTION_MAGNITUDE=0.7
DISTANCE_THRESHOLD=1.0
AVOIDANCE_MAGNITUDE=3.5
BUFFER_ZONE=8.0
WALL_FOLLOW_ZONE=4.0

# =============================================================================
# JAMMING RESPONSE CONFIGURATION
# =============================================================================

# Default obstacle type for new obstacles:
# - "none": No obstacle (pure simulation)
# - "physical": Hard obstacle (gray) - must path around completely
# - "low_jam": Low-power jamming (yellow) - proceed with caution, mild comm degradation
# - "high_jam": High-power jamming (red) - avoid strongly, severe comm degradation
DEFAULT_OBSTACLE_TYPE=low_jam

# Jamming detection parameters
JAMMING_DETECTION_RADIUS=15.0
JAMMING_SAFETY_MARGIN=3.0

# =============================================================================
# MAVLINK PROTOCOL CONFIGURATION
# =============================================================================

# Enable MAVLink message bus between agents (true/false)
# When enabled, agents communicate via signed messages instead of shared state
MAVLINK_ENABLED=true

# Base packet loss rate (0.0 = no loss, 1.0 = total loss)
# Actual loss is higher in jamming zones
MAVLINK_PACKET_LOSS_BASE=0.02

# =============================================================================
# SPOOFING ATTACK CONFIGURATION
# =============================================================================

# Default spoofing attack type for new zones:
# - "none": No spoofing
# - "phantom": Inject fake ghost agents
# - "position_falsification": Corrupt real agent positions with random offsets
# - "coordinate": Systematic position shift to lure swarm off course
DEFAULT_SPOOF_TYPE=phantom

# Phantom attack: number of ghost agents per spoofing zone
PHANTOM_COUNT=2

# Position falsification: magnitude of random offset (in simulation units)
POSITION_FALSIFICATION_MAGNITUDE=8.0

# Coordinate attack: systematic shift vector [x, y, z]
COORDINATE_ATTACK_VECTOR=[10.0, 10.0, 0.0]

# =============================================================================
# CRYPTOGRAPHIC AUTHENTICATION CONFIGURATION
# =============================================================================

# Enable crypto auth at startup (true/false)
# When enabled, MAVLink messages are signed and spoofed messages are rejected
CRYPTO_AUTH_ENABLED=false

# Default encryption algorithm:
# - "hmac_sha256": HMAC-SHA256 (MAC only, fastest)
# - "chacha20_poly1305": ChaCha20-Poly1305 (AEAD, encrypts + authenticates)
# - "aes_256_ctr": AES-256-CTR + HMAC-SHA256 (Encrypt-then-MAC, traditional)
# CRYPTO_ALGORITHM=hmac_sha256

# =============================================================================
# API CONFIGURATION
# =============================================================================

SIM_API_PORT=5001
CHAT_API_PORT=5000
